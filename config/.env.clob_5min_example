# ============================================================
#  POLYMARKET CLOB 5-MIN BOT  —  Environment Config
#  cp .env.example .env  then fill in your real values
#  NEVER commit .env to Git!
# ============================================================

# ── Polygon Private Key ────────────────────────────────────────
# Get from: MetaMask → Settings → Security & Privacy → Show Private Key
# DO NOT share this key!
POLYGON_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HEX

# ── CLOB L2 Server ────────────────────────────────────────────
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# ── Trading Parameters ────────────────────────────────────────
# Maximum single bet in USD
MAX_BET_USD=10.0

# Kelly Fraction (0.25 = quarter kelly, safer)
KELLY_FRACTION=0.25

# Minimum EV threshold to execute (0.08 = 0.8%)
MIN_EV_THRESHOLD=0.08

# Starting balance for backtesting/paper mode
STARTING_BALANCE=100.0

# ── Scanning ──────────────────────────────────────────────────
# Interval between scans in seconds (300 = 5 minutes)
SCAN_INTERVAL_SECONDS=300

# Paper trading mode (true = no real money, false = LIVE trading!)
PAPER_TRADING=true

# Markets to scan (comma-separated condition IDs)
# Example: "0x12345...,0x67890..."
# Leave empty to skip scanning
MARKETS=

# ── Optional: Telegram Alerts ─────────────────────────────────
# Get bot token: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal chat ID: @userinfobot on Telegram
TELEGRAM_CHAT_ID=
