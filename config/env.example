# ============================================================
#  Polymarket Momentum Bot v2.1  —  Environment Config
#  cp .env.example .env  then fill in your real values
#  NEVER commit .env to Git!
# ============================================================

# ── Wallet ────────────────────────────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HEX
CHAIN_ID=137

# ── Polymarket L2 API (CLOB signing) ─────────────────────────
API_KEY=YOUR_API_KEY
API_SECRET=YOUR_API_SECRET
API_PASSPHRASE=13aed5f4fc051d28d1723682b2a89ee16d097db0c298b0bbc12dbbaf66e9c63c

POLYMARKET_FUNDER_ADDRESS=0x27dfd1800145edb70659cc26f1bbc04a52e4cf27



# ── Relayer API (GASLESS — no MATIC gas needed!) ─────────────
# Get from: polymarket.com → Profile → Relayer API Keys
# Your key starts with: 019d361a...
RELAYER_API_KEY=YOUR_RELAYER_API_KEY
# Your signer address (visible on the Relayer API page)
RELAYER_API_KEY_ADDRESS=0x326f0bb3668eda3c729c3b3c83cd36ed5cae5dae

# ── Safety ────────────────────────────────────────────────────
DRY_RUN=true
INITIAL_BANKROLL=30.0

# ── Sizing ────────────────────────────────────────────────────
BASE_TRADE_SIZE=9
MAX_TRADE_SIZE=10
MIN_TRADE_SIZE=8
DAILY_LIMIT=150

# ── Strategy ─────────────────────────────────────────────────
MOMENTUM_THRESHOLD=0.05
STRONG_THRESHOLD=0.10
MIN_PRICE=0.32
MAX_PRICE=0.68
WINDOW_MIN_PCT=0.38
WINDOW_MAX_PCT=0.85

# ── Orders ────────────────────────────────────────────────────
SLIPPAGE_PCT=0.20
HYBRID_MODE=false
LIMIT_OFFSET_PCT=0.03
LIMIT_WAIT_SEC=7

# ── Runtime ───────────────────────────────────────────────────
LOOP_SEC=40

