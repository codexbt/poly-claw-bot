# SwissBot Environment Configuration
# Copy this file to .env and fill in your values

# ── Wallet Credentials ───────────────────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HEX
CHAIN_ID=137

# ── Polymarket CLOB API ──────────────────────────────────────────
CLOB_API_KEY=YOUR_CLOB_API_KEY
CLOB_SECRET=YOUR_CLOB_SECRET
CLOB_PASS_PHRASE=YOUR_CLOB_PASSPHRASE

# ── Endpoints (defaults work) ─────────────────────────────────────
# CLOB_HTTP_URL=https://clob.polymarket.com
# CLOB_WS_URL=wss://ws.polymarket.com/ws/user
# DATA_API_URL=https://data-api.polymarket.com

# ── Target Wallet to copy ─────────────────────────────────────────
# TARGET_WALLET=0x204f72f35326db932158cba6adff0b9a1da95e14  # swisstony

# ── Sizing Configuration ─────────────────────────────────────────
SWISSTONY_BALANCE=105000
SIZE_MULTIPLIER=1.0
CONCENTRATION_BOOST=3.0
MAX_POSITION_PER_GAME=150.0
MIN_TRADE_SIZE=1.0
MAX_TRADE_SIZE=500.0

# ── Risk Management ──────────────────────────────────────────────
MAX_SLIPPAGE=0.05
POLL_INTERVAL_MS=500
GAME_IDLE_TIMEOUT=1800
DAILY_LOSS_LIMIT=-100.0

# ── Mode ─────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=INFO